{
  "name": "sqler-mdb",
  "version": "3.1.1",
  "description": "@ugate/sqler dialect for MariaDB and/or MySQL",
  "main": "index.js",
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "testOLD": "lab -v -P test -c --coverage-exclude lib -t 85 -e prod",
    "testOLD-debug": "lab --inspect-brk -v -P test -c --coverage-exclude lib -t 85 -e prod",
    "testOLD-crud": "env NODE_ENV=test node test/lib/main.js crud",
    "test": "node --test test/main.test.js",
    "test-debug": "node --inspect-brk --test test/main.test.js",
    "test-crud": "NODE_ENV=test node --test --test-name-pattern='CRUD$' test/main.test.js",
    "docs:cp-test": "rm -rf docs/_test && mkdir -p docs/_test && cp -R test/* docs/_test",
    "docs:api": "rm -rf docs/api docs/api__index__.md docs/apitypedefs.md && node ./docs/generate-api.mjs",
    "docs:dev": "npm run docs:cp-test && npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:cp-test && npm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ugate/sqler-mdb.git"
  },
  "keywords": [
    "sqler",
    "sql",
    "MySQL",
    "MariaDB",
    "database"
  ],
  "author": "ugate",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ugate/sqler-mdb/issues"
  },
  "homepage": "https://ugate.github.io/sqler-mdb",
  "devDependencies": {
    "image-type": "^4.1.0",
    "mariadb": "^2.5.6",
    "moment-db": "^2.0.0",
    "read-chunk": "^3.2.0",
    "sqler": "^9.0.0",
    "vitepress": "^1.6.4",
    "vitepress-jsdoc": "^1.0.4"
  },
  "files": [
    "/index.js",
    "/lib/**/*"
  ]
}
